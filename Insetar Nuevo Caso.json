    {
      "parameters": {
        "operation": "executeQuery",
        "query": "SELECT \n    -- CASO CLÍNICO\n    cc.id as caso_id,\n    cc.fecha_inicio,\n    cc.fecha_fin,\n    cc.tipo_evento,\n    cc.origen_csv_drive,\n    \n    -- PACIENTE\n    p.id as paciente_id,\n    p.legajo,\n    p.legajo_con_ceros,\n    p.nombre_apellido as paciente,\n    \n    -- DIAGNÓSTICO\n    diag.id as diagnostico_id,\n    diag.nombre as diagnostico,\n    diag.detalle as diagnostico_detalle,\n    \n    -- UBICACIÓN\n    c.nombre as cia,\n    d.nombre as distrito,\n    bo.nombre as base_oficina,\n    \n    -- ESTADO DEL CASO\n    f.nombre as fase_caso,\n    s.color as semaforo_caso,\n    \n    -- AUDITORÍA\n    cc.created_at as fecha_creacion_caso,\n    cc.updated_at as fecha_actualizacion_caso\n    \nFROM caso_clinico cc\nJOIN paciente p ON cc.paciente_id = p.id\nLEFT JOIN diagnostico diag ON cc.diagnostico_id = diag.id\nLEFT JOIN base_of bo ON p.base_of_id = bo.id\nLEFT JOIN distrito d ON bo.distrito_id = d.id\nLEFT JOIN cia c ON d.cia_id = c.id\nLEFT JOIN fase f ON cc.fase_id = f.id\nLEFT JOIN semaforo s ON cc.semaforo_id = s.id\n\nWHERE cc.id = 1;  -- ← Cambiar por el ID del caso que quieres ver",
        "options": {}
      },
