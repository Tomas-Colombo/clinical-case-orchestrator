    {
      "parameters": {
        "jsCode": "// Obtener todos los items de entrada\nconst items = $input.all();\n\n// Transformar cada item: quedarnos con los datos del campo \"current\"\nconst result = items.map(item => {\n  const current = item.json.current;\n\n  // Si querés podés agregar un ID incremental, por ejemplo:\n  current.id = item.json.previous?.row_number || null;\n\n  return { json: current };\n});\n\nreturn result;\n"
      },
